order += "disk /"
order += "wireless _first_"
order += "ethernet _first_"
order += "cpu_temperature 0"
order += "cpu_usage"
order += "memory"
order += "tztime local"
order += "battery all"
order += "volume master"

disk "/" {
        format = "💾 %avail"
}

wireless _first_ {
        format_up = "📶 %essid (%quality)"
        format_down = "📶 down"
}

ethernet _first_ {
        format_up = "🌐 %ip"
        format_down = "🌐 down"
}
cpu_usage {
        format = "📊 %usage"
}

cpu_temperature 0 {
        format = "🌡️ %degrees °C"
        path = "/sys/devices/platform/coretemp.0/hwmon/hwmon*/temp1_input"
}
memory {
        format = "🧠 %used / %available"
        threshold_degraded = "1G"
        format_degraded = "MEMORY LOW: %available"
}

tztime local {
        format = "📅 %Y-%m-%d %H:%M:%S"
}

volume master {
        format = "🔊 %volume"
        format_muted = "🔇 muted (%volume)"
        device = "default"
        mixer = "Master"
        mixer_idx = 0
}

battery all {
        format = "%status %percentage %remaining"
        format_down = "No battery"
        status_chr = "⚡ CHR"
        status_bat = "🔋 BAT"
        status_unk = "? UNK"
        status_full = "☻ FULL"
        path = "/sys/class/power_supply/BAT%d/uevent"
        low_threshold = 10
        threshold_type = "percentage"
        last_full_capacity = true
}

general {
        colors = true
        interval = 5
        color_good = "#2AA198"      # Cyan for normal/good status
        color_degraded = "#CB4B16"  # Orange for warning thresholds
        color_bad = "#DC322F"       # Red for critical alerts
}

